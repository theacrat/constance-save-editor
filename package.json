{
	"name": "constance-save-editor",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "vite build",
		"cf-typegen": "wrangler types",
		"dev": "vite dev",
		"format": "oxfmt --write",
		"lint": "oxlint --fix --fix-suggestions",
		"serve": "node .output/server/index.mjs",
		"start": "bun run src/cli.ts",
		"test": "bun test",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@react-spectrum/s2": "^1.4.0",
		"@tanstack/react-router": "^1.170.15",
		"@tanstack/react-start": "^1.168.25",
		"fflate": "^0.8.2",
		"react": "^19.2.7",
		"react-dom": "^19.2.7"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.40.2",
		"@commitlint/cli": "^21.0.2",
		"@commitlint/config-conventional": "^21.0.2",
		"@types/bun": "latest",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.2",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"oxfmt": "^0.54.0",
		"oxlint": "^1.69.0",
		"oxlint-tsgolint": "^0.23.0",
		"typescript": "latest",
		"unplugin-parcel-macros": "^0.2.0",
		"vite": "^8.0.16",
		"wrangler": "^4.100.0"
	},
	"lint-staged": {
		"*": [
			"bun run lint --no-error-on-unmatched-pattern",
			"bun run format"
		]
	}
}
